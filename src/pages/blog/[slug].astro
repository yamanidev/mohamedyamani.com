---
import { type CollectionEntry, getCollection } from "astro:content";
import CustomLink from "../../components/CustomLink.astro";
import BlogPost from "../../layouts/BlogPost.astro";

type Props = CollectionEntry<"blog">;

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => data.language === "en");

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const englishPosts = (await getCollection("blog", ({ data }) => data.language === "en")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const post = Astro.props;
const { Content, remarkPluginFrontmatter } = await post.render();

const currentIndex = englishPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .findIndex((p) => p.slug === post.slug);

const previousPost = englishPosts[currentIndex + 1] || null;
const nextPost = englishPosts[currentIndex - 1] || null;

const lastModified = remarkPluginFrontmatter.lastModified;
---

<BlogPost
  {...post.data}
  lastModified={lastModified}
  nextPost={nextPost}
  previousPost={previousPost}>
  <Content slot="content" components={{ a: CustomLink }} />
</BlogPost>
