---
import BaseHead from "../components/BaseHead.astro";
import PageLayout from "../layouts/PageLayout.astro";
import EnvelopeIcon from "../components/svg/EnvelopeIcon.astro";
import GitHubLogo from "../components/svg/GitHubLogo.astro";
import LinkedInLogo from "../components/svg/LinkedInLogo.astro";
import XLogo from "../components/svg/XLogo.astro";

const EMAIL = "mohamed@yamani.dev";

const SOCIAL_LINKS = [
  {
    href: "https://www.linkedin.com/in/yamanidev/",
    label: "LinkedIn",
    description: "Professional network & work history",
    icon: LinkedInLogo,
  },
  {
    href: "https://github.com/yamanidev",
    label: "GitHub",
    description: "Open source projects & contributions",
    icon: GitHubLogo,
  },
  {
    href: "https://twitter.com/yamanidev",
    label: "Twitter / X",
    description: "Thoughts on software and the web",
    icon: XLogo,
  },
];
---

<PageLayout>
  <BaseHead
    title="Contact | Mohamed Yamani"
    description="Get in touch with Mohamed Yamani — open to tech talks, workshops, and collaborations."
    slot="meta"
  />
  <section class="py-20" slot="main">
    <div class="mx-auto max-w-6xl px-6 sm:px-8">
      <div class="max-w-xl">
        <h1 class="font-lora text-3xl font-bold italic sm:text-4xl">
          Get in touch
          <sub class="font-sans text-[0.625rem] font-normal not-italic">
            I am mostly friendly, I promise.
          </sub>
        </h1>
        <p class="mt-4 text-text-muted">
          Always happy to connect around tech, workshops, or interesting projects. Drop me a line or
          find me on any of the platforms below.
        </p>

        <div class="mt-12">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-text-muted">Email</p>
          <div class="flex items-center gap-3">
            <a
              href={`mailto:${EMAIL}`}
              class="inline-flex items-center gap-2 font-medium text-text-bold transition-colors hover:text-primary-main">
              <EnvelopeIcon width="18" height="18" />
              {EMAIL}
            </a>
            <button
              id="copy-email-btn"
              aria-label="Copy email address"
              class="rounded border border-current px-2.5 py-1 text-xs text-text-muted transition-colors hover:border-primary-main hover:text-primary-main">
              Copy
            </button>
          </div>
        </div>

        <div class="mt-12">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-text-muted">Online</p>
          <ul class="unset divide-y divide-neutral-200 dark:divide-neutral-800">
            {
              SOCIAL_LINKS.map(({ href, label, description, icon: Icon }) => (
                <li class="p-0">
                  <a
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="unset group flex items-center gap-4 py-4 transition-colors hover:text-primary-main">
                    <span class="text-text-muted transition-colors group-hover:text-primary-main">
                      <Icon width="20" height="20" />
                    </span>
                    <span class="flex flex-col gap-0.5">
                      <span class="text-sm font-medium text-text-bold transition-colors group-hover:text-primary-main">
                        {label}
                      </span>
                      <span class="text-xs text-text-muted">{description}</span>
                    </span>
                    <span class="ml-auto text-text-muted opacity-0 transition-opacity group-hover:opacity-100">
                      →
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const button = document.getElementById("copy-email-btn") as HTMLButtonElement;

  button.addEventListener("click", async () => {
    await navigator.clipboard.writeText("mohamed@yamani.dev");
    const original = button.textContent;
    button.textContent = "Copied!";

    setTimeout(() => {
      button.textContent = original;
    }, 2000);
  });
</script>
