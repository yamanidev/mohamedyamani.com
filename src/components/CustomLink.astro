---
// `href` prop from the MDX file
const { href, ...rest }: Record<string, any> = Astro.props;

// Heading anchor links injected by rehype-autolink-headings carry aria-hidden="true".
// Pass them through as-is — they're not content links.
const isHeadingAnchor = rest["aria-hidden"] === "true";

let attributes: { target?: string; rel?: string } = {};

const domain = import.meta.env.SITE;

// Open external links in new tabs
if (!isHeadingAnchor && !href.includes(domain) && !href.startsWith("/") && !href.startsWith("#")) {
  attributes["target"] = "_blank";
  attributes["rel"] = "noopener noreferrer";
}
---

{
  isHeadingAnchor ? (
    <a href={href} {...rest}>
      <slot />
    </a>
  ) : (
    <a href={href} {...attributes}>
      <slot />
    </a>
  )
}
