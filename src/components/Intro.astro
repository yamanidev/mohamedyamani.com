<section class="py-20 sm:py-40">
  <div class="mx-auto max-w-6xl px-6 sm:px-8">
    <div class="flex flex-col-reverse gap-8 sm:flex-row sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold sm:text-4xl md:text-5xl">
          <span>Mohamed Yamani,</span>
          <br />
          <span>Software Engineer</span>
          <br />
          <span class="text-xl font-normal italic sm:text-2xl md:text-3xl">
            —I build web experiences and write about it online.
          </span>
        </h1>
        <p class="mt-4 max-w-xl text-text-muted">
          Software engineer focused on building reliable, well-crafted web products. On the side, I
          write and speak about the things I learn — and occasionally help people navigate their
          early careers in tech.
        </p>
        <div class="mt-8 flex flex-wrap gap-4 font-lora font-bold italic">
          <a
            href="/blog/"
            class="unset rounded-md bg-primary-main px-6 py-2 text-bg-body transition hover:scale-105 sm:px-8">
            Blog
          </a>
          <a
            href="/contact/"
            class="unset rounded-md border-2 border-primary-main px-6 py-2 text-primary-main transition hover:scale-105 hover:bg-primary-main hover:text-bg-body sm:px-8">
            Get in touch
          </a>
        </div>
      </div>
      <img
        src="/images/mohamed-yamani.jpg"
        alt="Mohamed Yamani"
        width="192"
        height="192"
        class="h-32 w-32 shrink-0 rounded-full object-cover object-[center_30%] sm:h-48 sm:w-48"
      />
    </div>
  </div>
</section>
