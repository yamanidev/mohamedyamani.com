---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  thumbnailUrl?: string;
  ogType?: string;
  pubDate?: Date;
  modifiedDate?: Date;
  noindex?: boolean;
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description,
  thumbnailUrl,
  ogType = "website",
  pubDate,
  modifiedDate,
  noindex = false,
} = Astro.props;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Mohamed Yamani",
  url: "https://mohamedyamani.com",
  sameAs: [
    "https://twitter.com/yamanidev",
    "https://www.linkedin.com/in/yamanidev/",
    "https://github.com/yamanidev",
  ],
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content="Mohamed Yamani" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- RSS feed auto-discovery -->
<link
  rel="alternate"
  type="application/rss+xml"
  title="Mohamed Yamani's Blog"
  href={`${Astro.site}rss.xml`}
/>

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="Mohamed Yamani" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{thumbnailUrl && <meta property="og:image" content={new URL(thumbnailUrl, Astro.site)} />}

<!-- Article meta (blog posts only) -->
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{modifiedDate && <meta property="article:modified_time" content={modifiedDate.toISOString()} />}
{pubDate && <meta property="article:author" content="Mohamed Yamani" />}

<!-- Twitter -->
<meta name="twitter:creator" content="@yamanidev" />
<meta name="twitter:card" content={thumbnailUrl ? "summary_large_image" : "summary"} />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{thumbnailUrl && <meta name="twitter:image" content={new URL(thumbnailUrl, Astro.site)} />}

<!-- Person structured data (JSON-LD) -->
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
