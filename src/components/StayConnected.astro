---
type Props = {
  className?: string;
};

const { className } = Astro.props;
---

<div class={className}>
  <div class="overflow-hidden rounded-md border border-neutral-200 dark:border-neutral-800">
    <div class="flex items-start gap-4 p-6">
      <img
        src="/images/mohamed-yamani.jpg"
        alt="Mohamed Yamani"
        width="56"
        height="56"
        class="h-14 w-14 shrink-0 rounded-full object-cover object-[center_30%]"
      />
      <div>
        <p class="text-sm font-semibold text-text-bold">Mohamed Yamani</p>
        <p class="mt-0.5 text-sm text-text-muted">
          Software engineer focused on building reliable, well-crafted web products. I write about
          the things I learn along the way.
        </p>
      </div>
    </div>
    <div
      class="flex flex-col gap-2 border-t border-neutral-200 bg-neutral-50 px-6 py-4 dark:border-neutral-800 dark:bg-neutral-900 sm:flex-row sm:items-center sm:justify-between sm:py-3">
      <p class="text-sm text-text-muted">
        Get in touch or find me online — I'm always happy to connect.
      </p>
      <a
        href="/contact/"
        class="unset shrink-0 text-sm font-medium text-primary-main hover:underline">
        Get in touch →
      </a>
    </div>
  </div>
</div>
