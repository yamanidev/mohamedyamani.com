---
import DarkModeToggle from "./DarkModeToggle.astro";
import NavbarLink from "./NavbarLink.astro";
import Logo from "./svg/Logo.astro";
import type { Language } from "../types";
import { getRelativeLocaleUrl } from "astro:i18n";

const currentLocale = Astro.currentLocale as Language;

const translationContent = {
  en: {
    skip: "Skip to content",
    name: "Mohamed Yamani",
    blog: "Blog",
    talks: "Talks",
    contact: "Contact",
  },
  "ar-DZ": {
    skip: "تخط إلى المحتوى",
    name: "محمد يماني",
    blog: "مدونة",
    talks: "مداخلات",
    contact: "اتصال",
  },
} as const;

const t = translationContent[currentLocale];
---

<header
  class="sticky inset-x-0 top-0 z-10 bg-[rgba(var(--color-bg-body-rgb)/0.4)] py-2.5 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl justify-between px-6 sm:px-8">
    <a
      class="unset absolute -top-[100rem] left-[50%] z-10 translate-x-[-50%] bg-white px-8 py-2 text-black focus:top-[initial]"
      href="#main">
      {t.skip}
    </a>
    <a
      href={getRelativeLocaleUrl(currentLocale, "/")}
      class="unset flex items-center gap-2 font-lora font-bold italic text-text-bold rtl:not-italic">
      <Logo width="27" height="50" />
      <span>{t.name}</span>
    </a>

    <div class="flex items-center gap-2 sm:gap-4">
      <button id="menuToggleButton" class="text-text-bold focus:outline-none md:hidden">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16m-7 6h7">
          </path>
        </svg>
      </button>

      <div class="hidden items-center gap-8 md:flex">
        <nav class="text-sm font-semibold text-text-bold">
          <ul class="unset flex gap-4 [&>li]:p-0">
            <li>
              <NavbarLink href={getRelativeLocaleUrl(currentLocale, "/blog/")}>{t.blog}</NavbarLink>
            </li>
            <li>
              <NavbarLink href={getRelativeLocaleUrl(currentLocale, "/talks/")}
                >{t.talks}</NavbarLink
              >
            </li>
            <li>
              <NavbarLink href={getRelativeLocaleUrl(currentLocale, "/contact/")}
                >{t.contact}</NavbarLink
              >
            </li>
          </ul>
        </nav>
      </div>
      <DarkModeToggle />
    </div>
  </div>

  <div
    id="mobileMenu"
    class="hidden px-6 pt-4 text-sm font-semibold text-text-bold sm:px-8 md:hidden">
    <nav>
      <ul class="unset [&>li]:px-0">
        <li class="py-4">
          <NavbarLink href={getRelativeLocaleUrl(currentLocale, "/blog/")}>{t.blog}</NavbarLink>
        </li>
        <li class="py-4">
          <NavbarLink href={getRelativeLocaleUrl(currentLocale, "/talks/")}>{t.talks}</NavbarLink>
        </li>
        <li class="py-4">
          <NavbarLink href={getRelativeLocaleUrl(currentLocale, "/contact/")}
            >{t.contact}</NavbarLink
          >
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const menuToggleButton = document.getElementById("menuToggleButton") as HTMLButtonElement;
  const mobileMenu = document.getElementById("mobileMenu") as HTMLDivElement;

  menuToggleButton.addEventListener("click", () => {
    mobileMenu.classList.toggle("hidden");
  });
</script>
